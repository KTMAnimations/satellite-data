# Production .env for the geotiles.tech backend.
# Place this file at:  /opt/satellite-data/.env
# Keep it OFF git (it is git-ignored). Contains no secrets except the GEE key PATH.

ENVIRONMENT=production
DEBUG=false

# Google Earth Engine — project is known; key is the file you drop on the server.
GEE_PROJECT_ID=logical-carver-485406-t0
GEE_SERVICE_ACCOUNT_KEY=/opt/satellite-data/backend/credentials/gee-service-account.json

# Local storage (resolved against the repo root = /opt/satellite-data)
DATABASE_PATH=data/satellite.sqlite3
EXPORTS_DIR=data/exports

# Tile disk cache (raise if you have disk to spare; 0 disables)
TILE_CACHE_DIR=data/tile_cache
TILE_CACHE_MAX_MB=2000

# Same-origin in production (nginx proxies /api on geotiles.tech), but harmless to allow.
CORS_ORIGINS=https://geotiles.tech

# Required in production to use the in-app admin pages, including the Earth
# Engine key-upload page (Admin → Credentials). Generate with: openssl rand -hex 32
# Then paste the same value into the admin page's ADMIN_TOKEN field.
ADMIN_TOKEN=choose-a-long-random-string
