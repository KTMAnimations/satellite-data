# Repo-root .env for local runs (no Docker required)

# Backend mode
ENVIRONMENT=development
DEBUG=true

# Google Earth Engine
GEE_PROJECT_ID=your-gcp-project-id
# Optional: path to a service account JSON key. If unset, use `earthengine authenticate`.
GEE_SERVICE_ACCOUNT_KEY=credentials/gee-service-account.json

# Earth Engine throttling (global, in-process)
# Lower this if you see EE quota/latency issues during fast pans/zooms.
GEE_MAX_CONCURRENT_REQUESTS=8

# Local storage
DATABASE_PATH=data/satellite.sqlite3
EXPORTS_DIR=data/exports

# Tile PNG disk cache (backend tile proxy)
# Set TILE_CACHE_MAX_MB=0 to disable.
TILE_CACHE_DIR=data/tile_cache
TILE_CACHE_MAX_MB=200

# CORS (comma-separated or JSON list)
# Examples:
# CORS_ORIGINS=http://localhost:5173
# CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
CORS_ORIGINS=http://localhost:5173
