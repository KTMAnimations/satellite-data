# Repo-root .env for local runs (no Docker required)

# Backend mode
ENVIRONMENT=development
DEBUG=true

# Google Earth Engine
GEE_PROJECT_ID=your-gcp-project-id
# Optional: path to a service account JSON key. If unset, use `earthengine authenticate`.
GEE_SERVICE_ACCOUNT_KEY=credentials/gee-service-account.json

# Local storage
DATABASE_PATH=data/satellite.sqlite3
EXPORTS_DIR=data/exports

# CORS (comma-separated or JSON list)
# Examples:
# CORS_ORIGINS=http://localhost:5173
# CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
CORS_ORIGINS=http://localhost:5173
