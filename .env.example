# Google Earth Engine (Primary)
# Get credentials: https://console.cloud.google.com → APIs & Services → Credentials
GEE_PROJECT_ID=your-gcp-project-id
GEE_SERVICE_ACCOUNT_KEY=credentials/gee-service-account.json

# Microsoft Planetary Computer (Backup - no key needed for public data)
PC_SUBSCRIPTION_KEY=

# Sentinel Hub / Copernicus Data Space (Backup)
# Get credentials: https://dataspace.copernicus.eu → Dashboard → User Settings → OAuth Clients
SENTINELHUB_CLIENT_ID=
SENTINELHUB_CLIENT_SECRET=

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/satellite_data

# Redis
REDIS_URL=redis://localhost:6379

# API
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=change-this-to-a-random-string

# CORS (comma-separated or JSON list)
# Examples:
# CORS_ORIGINS=https://<user>.github.io,http://localhost:5173
# CORS_ORIGINS=["https://<user>.github.io","http://localhost:5173"]
CORS_ORIGINS=
