# Application
ENVIRONMENT=development
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://satellite:satellite_dev@localhost:5432/satellite_data

# Redis
REDIS_URL=redis://localhost:6379/0

# Data paths
DATA_DIR=/data
CACHE_DIR=/data/cache
EXPORTS_DIR=/data/exports

# Google Earth Engine (optional - for GEE provider)
# GEE_SERVICE_ACCOUNT=your-service-account@project.iam.gserviceaccount.com
# GEE_KEY_FILE=/path/to/service-account-key.json

# Microsoft Planetary Computer (optional)
# PLANETARY_COMPUTER_SUBSCRIPTION_KEY=your-key

# Sentinel Hub (optional - freemium)
# SENTINEL_HUB_CLIENT_ID=your-client-id
# SENTINEL_HUB_CLIENT_SECRET=your-client-secret

# Processing limits
MAX_REGION_AREA_KM2=50000
DEFAULT_CLOUD_COVER_THRESHOLD=20

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60
