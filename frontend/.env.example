# Frontend env for local dev (Vite). Copy to frontend/.env and fill in.
# NOTE: any VITE_* value is bundled into the client and is publicly visible.
# Use a MapTiler key that is domain-restricted / safe for public exposure.

# Base path for the API (relative or absolute)
VITE_API_URL=/api/v1

# MapTiler key for the optional OSM raster basemap (leave empty to disable)
VITE_MAPTILER_KEY=
